{
  "$Comment": "Flying hold behavior for aerial companions. Uses Tamework-style naming and parameter layout for later upstreaming.",
  "Type": "Component",
  "Class": "Instruction",
  "Interface": "Tamework.Instruction.Hold",
  "Parameters": {
    "HoldGroundAnimation": {
      "Value": "Idle",
      "Description": "Animation to apply once the companion is grounded in hold mode."
    },
    "HoldLandingSearchRange": {
      "Value": 20,
      "Description": "Search-ray range used to find a landing spot while entering grounded hold."
    },
    "HoldLandingSearchAngle": {
      "Value": 45,
      "Description": "Search-ray angle used to find a landing spot while entering grounded hold."
    },
    "HoldLandingSlowDownDistance": {
      "Value": 5,
      "Description": "Distance from landing point where descent begins to slow."
    },
    "HoldLandingStopDistance": {
      "Value": 0.5,
      "Description": "Distance from landing point considered grounded enough for hold."
    },
    "HoldLandingGoalLenience": {
      "Value": 3,
      "Description": "Goal lenience used during landing descent."
    }
  },
  "Content": {
    "$Comment": "Release combat targets, land if airborne, then stay grounded with the landed idle posture.",
    "Continue": true,
    "Sensor": {
      "Type": "Any"
    },
    "Instructions": [
      {
        "$Comment": "Keep combat target released while in hold mode.",
        "Continue": true,
        "Sensor": {
          "Type": "Any",
          "Once": true
        },
        "Actions": [
          {
            "Type": "ReleaseTarget",
            "TargetSlot": "LockedTarget"
          },
          {
            "Type": "SetFlag",
            "Name": "HoldFlying_GroundedPoseApplied",
            "SetTo": false
          }
        ]
      },
      {
        "$Comment": "While airborne, keep descending toward a valid landing spot.",
        "Continue": true,
        "Sensor": {
          "Type": "MotionController",
          "MotionController": "Fly"
        },
        "Instructions": [
          {
            "Actions": [
              {
                "Type": "SetFlag",
                "Name": "HoldFlying_GroundedPoseApplied",
                "SetTo": false
              }
            ]
          },
          {
            "Sensor": {
              "Type": "AdjustPosition",
              "Offset": [
                0,
                1,
                0
              ],
              "Sensor": {
                "Type": "SearchRay",
                "Name": "HoldLandingRay",
                "Range": {
                  "Compute": "HoldLandingSearchRange"
                },
                "Angle": {
                  "Compute": "HoldLandingSearchAngle"
                },
                "Blocks": "Gaia"
              }
            },
            "BodyMotion": {
              "Type": "Land",
              "SlowDownDistance": {
                "Compute": "HoldLandingSlowDownDistance"
              },
              "StopDistance": {
                "Compute": "HoldLandingStopDistance"
              },
              "GoalLenience": {
                "Compute": "HoldLandingGoalLenience"
              }
            }
          },
          {
            "BodyMotion": {
              "Type": "Wander",
              "RelativeSpeed": 0.1
            }
          }
        ]
      },
      {
        "$Comment": "Apply the landed idle pose once the companion reaches the ground.",
        "Enabled": {
          "Compute": "!isEmpty(HoldGroundAnimation)"
        },
        "Continue": true,
        "Sensor": {
          "Type": "And",
          "Sensors": [
            {
              "Type": "MotionController",
              "MotionController": "Walk"
            },
            {
              "Type": "Flag",
              "Name": "HoldFlying_GroundedPoseApplied",
              "Set": false
            }
          ]
        },
        "Actions": [
          {
            "Type": "ResetSearchRays"
          },
          {
            "Type": "PlayAnimation",
            "Slot": "Status",
            "Animation": {
              "Compute": "HoldGroundAnimation"
            }
          },
          {
            "Type": "SetFlag",
            "Name": "HoldFlying_GroundedPoseApplied",
            "SetTo": true
          }
        ]
      },
      {
        "$Comment": "Once grounded, remain stationary in the landed posture.",
        "Sensor": {
          "Type": "MotionController",
          "MotionController": "Walk"
        },
        "BodyMotion": {
          "Type": "Nothing"
        }
      }
    ]
  }
}
